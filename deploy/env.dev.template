# Tomodachi dev template
# Store real values in GitHub Environment secrets, cloud secret manager, or a VM-local env file.
# Do not commit filled credentials.

TOMODACHI_ENV=dev
SPRING_PROFILES_ACTIVE=dev

COMPOSE_PROJECT_NAME=tomodachi-dev
POSTGRES_DB=tomodachi
POSTGRES_USER=tomodachi
POSTGRES_PASSWORD=dev_postgres_password_placeholder
POSTGRES_PORT=5432

TOMODACHI_BACKEND_PORT=8080
TOMODACHI_FRONTEND_PORT=5173
TOMODACHI_DATABASE_URL=jdbc:postgresql://db:5432/tomodachi
TOMODACHI_DATABASE_USER=tomodachi
TOMODACHI_DATABASE_PASSWORD=dev_postgres_password_placeholder

TOMODACHI_BACKEND_IMAGE=ghcr.io/wonderrabbit/tomodachi-backend
TOMODACHI_FRONTEND_IMAGE=ghcr.io/wonderrabbit/tomodachi-frontend
TOMODACHI_IMAGE_TAG=dev

TOMODACHI_DOMAIN=dev.tomodachi.example.com
TOMODACHI_TLS_EMAIL=ops@example.com
TOMODACHI_PUBLIC_HTTP_BIND=0.0.0.0:80
TOMODACHI_PUBLIC_HTTPS_BIND=0.0.0.0:443
TOMODACHI_DB_VOLUME=tomodachi-dev-postgres-data
TOMODACHI_BACKUP_VOLUME=tomodachi-dev-postgres-backups
